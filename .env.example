# ============================================
# ACT LAB — Environment Variables
# ============================================
# Copy file ini ke .env dan isi nilainya
# 
# cp .env.example .env
# ============================================

# PORT — Port untuk server (default: 3000)
# Railway akan otomatis set PORT, tidak perlu diubah
# PORT=3000

# SESSION_SECRET — Secret key untuk cookie signing
# Gunakan string random yang panjang untuk production!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-super-secret-key-change-this

# NODE_ENV — Environment mode
# production, development, atau test
NODE_ENV=production

# ============================================
# DATABASE (Opsional — default pakai SQLite)
# ============================================
# Jika kosong, akan pakai SQLite (actlab.db)
# Jika diisi, akan pakai PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/actlab

# ============================================
# RAILWAY — Otomatis di-set oleh Railway
# ============================================
# RAILWAY_SERVICE_ID=xxx
# RAILWAY_PUBLIC_DOMAIN=xxx.railway.app
