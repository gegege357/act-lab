# ============================================
# ACT LAB — Environment Variables
# ============================================
# Copy file ini ke .env dan isi nilainya
# 
# cp .env.example .env
# ============================================

# PORT — Port untuk server lokal (default: 3000)
# PORT=3000

# SESSION_SECRET — Secret key untuk cookie signing
# Gunakan string random yang panjang untuk production!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-super-secret-key-change-this

# NODE_ENV — Environment mode
# production, development, atau test
NODE_ENV=production

# ============================================
# DATABASE
# ============================================
# Jika kosong, ACT LAB pakai SQLite.
# Di Vercel, SQLite otomatis dibuat sementara di /tmp dan di-seed saat cold start.
